---
// layout
import Layout from "../../layout/Layout.astro"

// routing
import type { GetStaticPaths } from "astro";
import { render } from "astro:content";
import { getCollection } from "astro:content";
export const getStaticPaths = (async () => {
    const projects = await getCollection("projects", ({data}) => !data.isDraft)
    return projects.map((project) => ({
        params: {
            page: project.data.slug,
        },
        props: {
            project,
        }
    }));
}) satisfies GetStaticPaths;

// props
const { project } = Astro.props;
const { Content } = await render(project);
const { title, client, category, year, description, featuredImage, liveSite } = project.data;
const details = [
    { heading: "Client", text: `${client}` },
    { heading: "Category", text: `${category}` },
    { heading: "Year", text: `${year}` }
]
---

<Layout
    title=""
    description=""
    ogImage=""
    canonical="https://jessgaspar.dev/"
    
>
</Layout>
